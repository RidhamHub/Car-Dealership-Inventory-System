{
  "name": "car-dealership-server",
  "version": "1.0.0",
  "description": "Car dealership inventory REST API (Express + MongoDB, TDD)",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node scripts/seed.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "cross-env": "^10.1.0",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.6",
    "supertest": "^7.2.2",
    "vitest": "^4.1.10"
  }
}
